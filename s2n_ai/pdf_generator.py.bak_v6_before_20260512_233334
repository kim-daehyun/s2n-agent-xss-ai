def _compact_url(url: Any) -> str:
    text = _clean_text(url)
    if not text:
        return "-"
    try:
        parsed = urlparse(text)
        if parsed.path:
            compact = parsed.path
            if parsed.query:
                qs = parse_qs(parsed.query)
                if "name" in qs:
                    compact += "?name=..."
                else:
                    compact += "?..."
            return compact
    except Exception:
        pass
    return text


def _short_payload(payload: Any) -> str:
    text = _clean_text(payload)
    if not text:
        return "-"
    # 표가 깨지지 않도록 요약표에서는 대표 페이로드만 짧게 표기
    if "<script>alert(1)</script>" in text:
        if text.startswith('">'):
            return '"><script>alert(1)</script>'
        return "<script>alert(1)</script>"
    if len(text) > 34:
        return text[:31] + "..."
    return text


def _code_inline(value: Any) -> str:
    return f'<code class="inline-code">{escape(_safe(value))}</code>'


def _manual_bullets(items: List[Any]) -> str:
    cleaned = [_clean_text(x) for x in items if _clean_text(x)]
    if not cleaned:
        return "<p>-</p>"
    rows = []
    for item in cleaned:
        rows.append(f'<p class="bullet-line">• {escape(item)}</p>')
    return '<div class="manual-list">' + "\n".join(rows) + "</div>"


def _manual_numbers(items: List[Any]) -> str:
    cleaned = [_clean_text(x) for x in items if _clean_text(x)]
    if not cleaned:
        return "<p>-</p>"
    rows = []
    for idx, item in enumerate(cleaned, start=1):
        rows.append(f'<p class="number-line"><strong>{idx}.</strong> {escape(item)}</p>')
    return '<div class="manual-list">' + "\n".join(rows) + "</div>"


def _paragraphs(text: str) -> str:
    text = _clean_markdown(text)
    if not text:
        return "<p>-</p>"

    html_parts: List[str] = []
    pending_bullets: List[str] = []

    def flush_bullets() -> None:
        nonlocal pending_bullets
        if pending_bullets:
            html_parts.append(_manual_bullets(pending_bullets))
            pending_bullets = []

    for raw in text.splitlines():
        line = raw.strip()
        if not line:
            flush_bullets()
            continue
        if line.startswith("- "):
            pending_bullets.append(line[2:].strip())
        else:
            flush_bullets()
            html_parts.append(f"<p>{escape(line)}</p>")

    flush_bullets()
    return "\n".join(html_parts)


def _evidence_get(evidence: Any, key: str, default: Any = None) -> Any:
    if isinstance(evidence, dict):
        return evidence.get(key, default)

    text = "" if evidence is None else str(evidence)
    lower = text.lower()

    if key in ("reflection", "reflected", "reflection_detected"):
        markers = [
            "reflected in http response",
            "payload reflected",
            "payload already present",
            "direct_url_payload_reflected",
            "verification=payload_reflected",
            "verification=direct_url_payload_reflected",
            "without clear output encoding",
            "reflected_value=",
            "was reflected",
        ]
        return any(marker in lower for marker in markers)

    if key in ("reflected_value", "payload"):
        for marker in ("reflected_value=", "payload="):
            if marker in text:
                return text.split(marker, 1)[1].split(";", 1)[0].strip()
        return default

    if key in ("verification", "verified"):
        if "direct_url_payload_reflected" in text:
            return "direct_url_payload_reflected"
        if "verification=payload_reflected" in text or "payload reflected" in lower:
            return "payload_reflected"
        return default

    if key in ("snippet", "response_snippet", "body", "raw"):
        if "snippet=" in text:
            return text.split("snippet=", 1)[1].strip()
        return text if text else default

    return default


def _get_report_field(finding: Dict[str, Any], key: str, default: Any = None) -> Any:
    report_fields = finding.get("report_fields") or {}
    if isinstance(report_fields, dict) and key in report_fields:
        return report_fields.get(key, default)
    if key in finding:
        return finding.get(key, default)
    raw = finding.get("raw_result") or {}
    if isinstance(raw, dict):
        return raw.get(key, default)
    return default


def _risk(finding: Dict[str, Any], key: str, default: Any = None) -> Any:
    risk = finding.get("risk") or {}
    if isinstance(risk, dict):
        return risk.get(key, default)
    return default


def _agent(finding: Dict[str, Any], key: str, default: Any = None) -> Any:
    agent_response = finding.get("agent_response") or {}
    if isinstance(agent_response, dict):
        return agent_response.get(key, default)
    return default


def _context_content(ctx: Dict[str, Any]) -> str:
    return _clean_markdown(
        ctx.get("content")
        or ctx.get("text")
        or ctx.get("page_content")
        or ctx.get("snippet")
        or ctx.get("body")
        or ctx.get("document")
        or ctx.get("chunk")
        or "",
        limit=1700,
    )


def _looks_like_context(ctx: Dict[str, Any]) -> bool:
    if not isinstance(ctx, dict):
        return False
    if _context_content(ctx):
        return True
    useful_keys = {"source", "path", "url", "title", "name", "retriever", "score", "similarity"}
    return any(_clean_text(ctx.get(k)) for k in useful_keys)


def _extract_contexts_recursive(raw: Any) -> List[Dict[str, Any]]:
    contexts: List[Dict[str, Any]] = []

    if raw is None:
        return contexts

    if isinstance(raw, list) or isinstance(raw, tuple):
        for item in raw:
            contexts.extend(_extract_contexts_recursive(item))
        return contexts

    if not isinstance(raw, dict):
        text = _clean_text(raw)
        return [{"title": "Retrieved Context", "content": text}] if text else []

    docs = raw.get("documents")
    metas = raw.get("metadatas")
    distances = raw.get("distances")
    if docs is not None:
        doc_items = docs[0] if docs and isinstance(docs, list) and docs and isinstance(docs[0], list) else docs
        meta_items = metas[0] if metas and isinstance(metas, list) and metas and isinstance(metas[0], list) else metas
        dist_items = distances[0] if distances and isinstance(distances, list) and distances and isinstance(distances[0], list) else distances

        if isinstance(doc_items, list):
            for idx, doc in enumerate(doc_items):
                meta = {}
                if isinstance(meta_items, list) and idx < len(meta_items) and isinstance(meta_items[idx], dict):
                    meta = dict(meta_items[idx])
                score = "-"
                if isinstance(dist_items, list) and idx < len(dist_items):
                    score = dist_items[idx]
                meta.setdefault("content", doc)
                meta.setdefault("retriever", raw.get("retriever") or "chroma")
                meta.setdefault("score", score)
                contexts.append(meta)

    for key in ("internal", "external", "contexts", "rag_contexts", "results", "matches", "items"):
        if key in raw:
            contexts.extend(_extract_contexts_recursive(raw.get(key)))

    if _looks_like_context(raw):
        contexts.append(raw)

    return contexts


def _normalize_rag_contexts(raw: Any) -> List[Dict[str, Any]]:
    contexts = _extract_contexts_recursive(raw)

    normalized: List[Dict[str, Any]] = []
    seen = set()
    for ctx in contexts:
        if not isinstance(ctx, dict):
            continue
        content = _context_content(ctx)
        source = _clean_text(ctx.get("source") or ctx.get("path") or ctx.get("url") or "")
        title = _clean_text(ctx.get("title") or ctx.get("name") or "")
        retriever = _clean_text(ctx.get("retriever") or "")

        if not content and not source and not title:
            continue

        key = (title.lower(), source.lower(), content[:180].lower())
        if key in seen:
            continue
        seen.add(key)

        copied = dict(ctx)
        if content:
            copied["content"] = content
        if not copied.get("retriever") and retriever:
            copied["retriever"] = retriever
        normalized.append(copied)

    return normalized


