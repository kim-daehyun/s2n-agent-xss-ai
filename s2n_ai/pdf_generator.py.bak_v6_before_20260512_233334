# Converts the fragile wide All Findings Summary table into a vertical finding card.
try:
    from reportlab.lib import colors as _s2n_colors
    from reportlab.lib.styles import ParagraphStyle as _S2NParagraphStyle
    from reportlab.platypus import Paragraph as _S2NParagraph
    from reportlab.platypus import Table as _S2NReportLabTable
    from reportlab.platypus import TableStyle as _S2NTableStyle
    from xml.sax.saxutils import escape as _s2n_escape_xml

    if "Table" not in globals():
        Table = _S2NReportLabTable

    if "_S2N_ORIGINAL_TABLE_V4" not in globals():
        _S2N_ORIGINAL_TABLE_V4 = Table

    def _s2n_plain(value):
        if value is None:
            return "-"
        try:
            if hasattr(value, "getPlainText"):
                return str(value.getPlainText())
        except Exception:
            pass
        try:
            if hasattr(value, "text"):
                return str(value.text)
        except Exception:
            pass
        return str(value)

    def _s2n_break_long_token(token, chunk=18):
        if len(token) <= chunk:
            return token
        return "<br/>".join(token[i:i + chunk] for i in range(0, len(token), chunk))

    def _s2n_wrap_value(value):
        s = _s2n_escape_xml(_s2n_plain(value))
        s = s.replace(chr(13), "")
        s = s.replace(chr(10), "<br/>")
        for sep in ["&amp;", "&lt;", "&gt;", "%", "?", "=", "/", ".", "_", "-", ":", ";", "(", ")", "[", "]", "{", "}", ",", "'", "`", chr(34)]:
            s = s.replace(sep, sep + "<br/>")
        return "<br/>".join(_s2n_break_long_token(part) for part in s.split("<br/>"))

    def _s2n_para(value, bold=False, code=False, size=None):
        font_name = "Courier" if code else ("Helvetica-Bold" if bold else "Helvetica")
        if size is None:
            size = 6.8 if code else 7.2
        return _S2NParagraph(
            _s2n_wrap_value(value),
            _S2NParagraphStyle(
                name="S2NVerticalCellV4",
                fontName=font_name,
                fontSize=size,
                leading=size + 1.8,
                wordWrap="CJK",
                splitLongWords=True,
                spaceBefore=0,
                spaceAfter=0,
            ),
        )

    def _s2n_headers(data):
        try:
            return [_s2n_plain(c).strip().lower() for c in data[0]]
        except Exception:
            return []

    def _s2n_is_summary_table(data):
        headers = set(_s2n_headers(data))
        required = {"id", "severity", "confidence", "param", "payload", "verification"}
        return required.issubset(headers)

    def _s2n_map_row(headers, row):
        values = [_s2n_plain(c) for c in row]
        return {h: values[i] if i < len(values) else "-" for i, h in enumerate(headers)}

    def _s2n_yes_no(value):
        raw = _s2n_plain(value).strip().lower()
        if raw in ("true", "1", "yes", "y"):
            return "Yes"
        if raw in ("false", "0", "no", "n"):
            return "No"
        return _s2n_plain(value)

    def _s2n_human_verification(value):
        raw = _s2n_plain(value)
        low = raw.lower()
        if "browser_dialog" in low or "dialog" in low:
            return "Browser alert/dialog observed"
        if "payload_reflected" in low:
            return "Payload reflected in HTTP response"
        if "direct_url_payload" in low:
            return "Payload reflected in direct URL response"
        if "reflected" in low:
            return "Payload reflected"
        return raw or "-"

    def _s2n_browser_confirmed(payload, verification, row_map):
        blob = " ".join([
            _s2n_plain(payload),
            _s2n_plain(verification),
            _s2n_plain(row_map.get("xss type", "")),
            _s2n_plain(row_map.get("detection type", "")),
            _s2n_plain(row_map.get("discovery mode", "")),
        ]).lower()
        return (
            "browser_dialog" in blob
            or "browser" in blob
            or "dom" in blob
            or "javascript:alert" in blob
            or "<iframe" in blob
        )

    def _s2n_vertical_finding_table(data):
        headers = _s2n_headers(data)
        rows = []
        title_rows = []

        for idx, row in enumerate(data[1:], start=1):
            item = _s2n_map_row(headers, row)
            payload = item.get("payload", "-")
            verification = item.get("verification", "-")
            reflected = item.get("reflected", "-")

            browser_ok = _s2n_browser_confirmed(payload, verification, item)
            detection_type = "DOM/browser-executed XSS" if browser_ok else "Reflected XSS"
            browser_confirmed = "Yes" if browser_ok else "Not confirmed by browser probe"
            server_reflected = _s2n_yes_no(reflected)

            if browser_ok:
                interpretation = (
                    "Browser execution evidence was observed. Server Reflected=No can still be valid "
                    "for DOM XSS because the vulnerable behavior is confirmed in the browser/DOM."
                )
            else:
                interpretation = "The payload was confirmed through HTTP reflection evidence."

            title_rows.append(len(rows))
            rows.append([_s2n_para(f"Finding #{idx}", bold=True, size=8.4), _s2n_para("", size=8.4)])

            pairs = [
                ("ID", item.get("id", "-"), False),
                ("Severity", item.get("severity", "-"), False),
                ("Confidence", item.get("confidence", "-"), False),
                ("Detection Type", detection_type, False),
                ("Target Path", item.get("target path", item.get("path", "-")), True),
                ("Parameter", item.get("param", item.get("parameter", "-")), False),
                ("Payload", payload, True),
                ("Verification", _s2n_human_verification(verification), False),
                ("Browser Execution Confirmed", browser_confirmed, False),
                ("Server Reflected", server_reflected, False),
                ("Interpretation", interpretation, False),
            ]

            for label, value, is_code in pairs:
                rows.append([_s2n_para(label, bold=True), _s2n_para(value, code=is_code)])

        tbl = _S2N_ORIGINAL_TABLE_V4(rows, colWidths=[135, 360], hAlign="LEFT", repeatRows=0)
        cmds = [
            ("GRID", (0, 0), (-1, -1), 0.35, _s2n_colors.HexColor("#C9CED6")),
            ("VALIGN", (0, 0), (-1, -1), "TOP"),
            ("LEFTPADDING", (0, 0), (-1, -1), 6),
            ("RIGHTPADDING", (0, 0), (-1, -1), 6),
            ("TOPPADDING", (0, 0), (-1, -1), 5),
            ("BOTTOMPADDING", (0, 0), (-1, -1), 5),
            ("BACKGROUND", (0, 0), (0, -1), _s2n_colors.HexColor("#EEF1F5")),
        ]
        for r in title_rows:
            cmds.append(("SPAN", (0, r), (1, r)))
            cmds.append(("BACKGROUND", (0, r), (1, r), _s2n_colors.HexColor("#DDE3EA")))
        tbl.setStyle(_S2NTableStyle(cmds))
        return tbl

    def Table(data, *args, **kwargs):  # noqa: N802
        try:
            if _s2n_is_summary_table(data):
                return _s2n_vertical_finding_table(data)
        except Exception as exc:
            try:
                print(f"[WARN] vertical finding summary fallback: {exc}")
            except Exception:
                pass
        return _S2N_ORIGINAL_TABLE_V4(data, *args, **kwargs)

except Exception as _s2n_patch_exc:
    try:
        print(f"[WARN] S2N vertical PDF patch not loaded: {_s2n_patch_exc}")
    except Exception:
        pass
# --- end S2N PDF vertical finding summary patch v4 ---

