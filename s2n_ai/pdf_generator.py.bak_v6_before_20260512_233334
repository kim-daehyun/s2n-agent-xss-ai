def generate_xss_pdf_report(
    finding: Dict[str, Any],
    rag_contexts: List[Dict[str, Any]] | Dict[str, Any] | None = None,
    pdf_path: str = DEFAULT_PDF_PATH,
    output_path: str | None = None,
    all_findings: Any = None,
    scan_summary: Dict[str, Any] | None = None,
    **_: Any,
) -> str:
    finding = finding or {}
    pdf_path = output_path or pdf_path or DEFAULT_PDF_PATH

    findings = _flatten_findings(finding, all_findings=all_findings)
    scan_summary = scan_summary or finding.get("_scan_summary") or {}

    evidence = _get_report_field(finding, "evidence", finding.get("evidence"))
    response_snippet = _get_report_field(
        finding,
        "response_snippet",
        _evidence_get(evidence, "response_snippet", ""),
    )

    all_contexts = _normalize_rag_contexts(rag_contexts)
    internal_contexts = [c for c in all_contexts if _context_source_type(c) == "internal"]
    external_contexts = [c for c in all_contexts if _context_source_type(c) == "external"]
    official_refs = _official_refs_from_finding(finding, external_contexts)

    title = _get_report_field(finding, "title", "Reflected Cross-Site Scripting Detected")
    severity = _get_report_field(finding, "severity", finding.get("severity", "HIGH"))
    confidence = _get_report_field(finding, "confidence", finding.get("confidence", "FIRM"))
    target_url = _get_report_field(finding, "target_url", finding.get("url"))
    parameter = _get_report_field(finding, "parameter", "-")
    payload = _get_report_field(finding, "payload", "-")
    reflected_value = _get_report_field(finding, "reflected_value", _evidence_get(evidence, "reflected_value", "-"))
    verification = _get_report_field(finding, "verification", _evidence_get(evidence, "verification", "-"))
    reflected = _get_report_field(finding, "reflection_detected", _evidence_get(evidence, "reflection", False))

    evidence_note = ""
    if isinstance(evidence, str) and ("www-comm" in evidence or evidence.endswith("comm") or evidence.endswith("co")):
        evidence_note = """
        <div class="notice">
          Note: the original S2N finding stores a truncated response snippet. The report preserves the scanner provided
          evidence and only adds a renderer truncation marker when the report renderer itself cuts long text.
        </div>
        """

    html = f"""<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>S2N XSS Security Report</title>
  <style>{_css()}</style>
</head>
<body>
  <section class="page">
    <h1>S2N XSS Security Report</h1>
    <p class="muted">Generated at: {escape(datetime.utcnow().isoformat())}Z</p>

    <h2>1. Executive Summary</h2>
    <p>This report was generated from an actual S2N scan result and describes confirmed XSS findings.</p>
    {_table([
        ("Primary Finding", title),
        ("Primary Severity", severity),
        ("Primary Confidence", confidence),
        ("Target URL", target_url),
        ("Affected Parameter", parameter),
        ("Primary Payload", payload),
        ("Total Findings", scan_summary.get("total_vulnerabilities") or len(findings)),
        ("Severity Counts", scan_summary.get("severity_counts") or "-"),
        ("Total Requests", scan_summary.get("total_requests") or "-"),
        ("Source Scanner", finding.get("source_scanner") or "s2n"),
        ("Source Plugin", finding.get("source_plugin") or "xss"),
    ])}
    <div class="okbox">
      The finding is confirmed because the scanner observed unsafe payload handling through HTTP reflection or browser execution evidence.
    </div>
  </section>

  <section class="page">
    <h2>2. All Findings Summary</h2>
    <p>The S2N scan detected the following XSS finding records. The following sections summarize each finding in a vertical detail format and then analyze the primary finding.</p>
    {_finding_summary_table(findings)}
  </section>

  <section class="page">
    <h2>3. Representative Finding Detail</h2>
    {_table([
        ("ID", finding.get("id") or finding.get("finding_id") or "-"),
        ("Title", title),
        ("Vulnerability Type", finding.get("vuln_type") or finding.get("vulnerability_type") or "XSS"),
        ("XSS Type", finding.get("xss_type") or "reflected"),
        ("CWE", finding.get("cwe") or "CWE-79"),
        ("OWASP Category", finding.get("owasp_category") or "Injection / Cross-Site Scripting"),
        ("HTTP Method", _get_report_field(finding, "method", _get_report_field(finding, "http_method", "GET"))),
        ("Parameter", parameter),
        ("Injection Context", finding.get("injection_context") or "-"),
        ("Reflection Detected", reflected),
        ("Reflected Value", reflected_value),
        ("Verification", verification),
        ("Risk Score", _risk(finding, "risk_score", "85")),
        ("Likelihood", _risk(finding, "likelihood", "High")),
        ("Impact", _risk(finding, "impact", "High")),
    ])}
    <h3>Description</h3>
    <p>{escape(_clean_text(finding.get("description") or "User-controlled input was reflected in the HTTP response without proper output encoding.", limit=900))}</p>
  </section>

  <section class="page">
    <h2>4. Evidence</h2>
    {evidence_note}
    <h3>Raw Evidence</h3>
    {_pre(evidence, limit=2600)}
    <h3>Response Snippet</h3>
    {_pre(response_snippet, limit=2200)}
  </section>

  <section class="page">
    <h2>5. XSSAgent Judgement</h2>
    {_table([
        ("Task", _agent(finding, "task", "-")),
        ("Should Run", _agent(finding, "should_run", "-")),
        ("Context Known", _agent(finding, "context_known", "-")),
        ("Selected Plugin", _agent(finding, "selected_plugin", "-")),
        ("Severity", _agent(finding, "severity", severity)),
        ("Confidence", _agent(finding, "confidence", confidence)),
        ("Fallback", _agent(finding, "fallback", "-")),
        ("Reason", _agent(finding, "reason", "-")),
    ])}
  </section>

  <section class="page">
    <h2>6. Risk & Remediation</h2>
    <h3>Risk</h3>
    {_table([
        ("Severity", severity),
        ("Risk Score", _risk(finding, "risk_score", "85")),
        ("Likelihood", _risk(finding, "likelihood", "High")),
        ("Impact", _risk(finding, "impact", "High")),
        ("Business Impact", _risk(finding, "business_impact", "An attacker may execute arbitrary JavaScript in a victim browser, steal session data, perform actions as the user, or manipulate page content.")),
    ])}

    <h3>Scoring Basis</h3>
    {_manual_bullets([
        "Severity is high because browser-executable JavaScript was confirmed by scanner evidence.",
        "Confidence is firm because the payload and execution/reflection evidence were verified by the scanner.",
        "Likelihood is high when user-controlled input is returned without context-aware output encoding.",
        "Impact is high because reflected script execution can lead to session theft, user action abuse, or page manipulation.",
    ])}

    <h3>Recommended Remediation</h3>
    {_manual_numbers([
        "Apply context-aware output encoding before inserting user-controlled input into HTML.",
        "Validate and constrain user input on the server side.",
        "Avoid directly reflecting raw request parameters into responses.",
        "Use safe DOM APIs such as textContent instead of innerHTML where possible.",
        "Add Content Security Policy as a defense-in-depth control.",
        "Re-test the affected parameter with the same payload after remediation.",
    ])}
  </section>

  <section class="page">
    <h2>7. Internal Knowledge Retrieved by ChromaDB</h2>
    {_render_internal_contexts(internal_contexts)}
  </section>

  <section class="page">
    <h2>8. Official Reference Mapping</h2>
{_render_external_refs(official_refs)}
  </section>

  <section class="page">
    <h2>9. Retest Recommendation</h2>
    <p>Re-run the S2N XSS plugin against the affected endpoint after remediation.</p>
    {_table([
        ("Target URL", target_url),
        ("Parameter", parameter),
        ("Payload", payload),
        ("Expected Secure Result", "The payload should be encoded or rejected and must not execute as JavaScript."),
    ])}

    <h3>Retest Steps</h3>
    {_manual_numbers([
        "Send the same GET request to the affected endpoint with the original payload.",
        "Verify that < and > are encoded as &lt; and &gt;, or that the input is rejected.",
        "Open the response in a browser and confirm that no JavaScript alert or script execution occurs.",
        "Re-run the S2N XSS plugin and confirm that the finding count for this endpoint is zero.",
    ])}
  </section>
</body>
</html>
"""

    out = Path(pdf_path)
    out.parent.mkdir(parents=True, exist_ok=True)

    try:
        from weasyprint import HTML
        HTML(string=html, base_url=str(Path.cwd())).write_pdf(str(out))
    except Exception as exc:
        html_path = out.with_suffix(".html")
        html_path.write_text(html, encoding="utf-8")
        raise RuntimeError(f"PDF generation failed. Debug HTML saved to {html_path}") from exc

    return str(out)


generate_pdf_report = generate_xss_pdf_report
