def _official_refs_from_finding(finding: Dict[str, Any], external_contexts: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
    if external_contexts:
        refs = []
        for ctx in external_contexts:
            refs.append({
                "title": ctx.get("title") or ctx.get("name") or "External Official Reference",
                "source": ctx.get("source") or ctx.get("url") or ctx.get("path") or "-",
                "source_mode": _display_source_mode(ctx.get("retriever") or "external_official"),
                "score": ctx.get("score") or ctx.get("similarity") or "-",
                "summary": _context_content(ctx),
            })
        return refs

    hints = finding.get("rag_hints") or {}
    hint_text = " ".join([
        " ".join(_as_list(hints.get("official_references"))),
        " ".join(_as_list(hints.get("recommended_docs"))),
        _safe(hints.get("cwe"), ""),
        _safe(finding.get("cwe"), ""),
        _safe(finding.get("vuln_type"), ""),
        _safe(finding.get("xss_type"), ""),
    ]).lower()

    catalog = _official_reference_catalog()
    keys = []
    if "owasp" in hint_text or "xss" in hint_text:
        keys.append("owasp")
    if "cwe-79" in hint_text or "cwe" in hint_text or "xss" in hint_text:
        keys.append("cwe-79")
    if "mdn" in hint_text or "xss" in hint_text:
        keys.append("mdn")
    if "portswigger" in hint_text or "reflected" in hint_text or "xss" in hint_text:
        keys.append("portswigger")
    if not keys:
        keys = ["owasp", "cwe-79", "mdn", "portswigger"]

    refs = []
    for key in dict.fromkeys(keys):
        item = catalog[key]
        refs.append({
            "title": item["title"],
            "source": item["source"],
            "source_mode": "official_catalog_fallback_not_live_web",
            "score": "fallback",
            "summary": item["summary"],
        })
    return refs


def _render_internal_contexts(contexts: List[Dict[str, Any]]) -> str:
    usable = []
    for ctx in contexts:
        if not isinstance(ctx, dict):
            continue
        content = _context_content(ctx)
        source = _clean_text(ctx.get("source") or ctx.get("path") or ctx.get("url") or "")
        title = _clean_text(ctx.get("title") or ctx.get("name") or "")
        if content or source or title:
            usable.append(ctx)

    if not usable:
        usable = _default_internal_contexts()

    parts = []
    for idx, ctx in enumerate(_dedupe_contexts(usable, limit=3), start=1):
        title = ctx.get("_render_title") or _context_title(ctx, idx)
        content = ctx.get("_render_content") or _context_content(ctx)

        parts.append(f"""
        <section class="subsection">
          <h3>7.{idx} {escape(title)}</h3>
          {_table([
              ("Source", ctx.get("source") or ctx.get("path") or "-"),
              ("Retriever", _display_retriever(ctx.get("retriever"))),
              ("Retrieval Score", ctx.get("score") or ctx.get("similarity") or "-"),
          ])}
          <div class="context-text">{_paragraphs(content)}</div>
        </section>
        """)
    return "\n".join(parts)


def _render_external_refs(refs: List[Dict[str, Any]]) -> str:
    if not refs:
        return "<p>No official reference mapping was available.</p>"

    parts = []
    for idx, ref in enumerate(refs, start=1):
        parts.append(f"""
        <section class="subsection ref-card">
          <h3>8.{idx} {escape(_safe(ref.get("title")))}</h3>
          {_table([
              ("Source", ref.get("source") or "-"),
              ("Source Mode", _display_source_mode(ref.get("source_mode") or "-")),
              ("Score", ref.get("score") or "-"),
          ])}
          <p>{escape(_clean_text(ref.get("summary"), limit=900))}</p>
        </section>
        """)
    return "\n".join(parts)


def _flatten_findings(primary_finding: Dict[str, Any], all_findings: Any = None) -> List[Dict[str, Any]]:
    candidates = []
    if all_findings:
        candidates = [x for x in _as_list(all_findings) if isinstance(x, dict)]
    elif isinstance(primary_finding.get("_all_findings"), list):
        candidates = [x for x in primary_finding.get("_all_findings", []) if isinstance(x, dict)]

    if not candidates:
        raw = primary_finding.get("raw_result") or {}
        if isinstance(raw, dict):
            candidates = [raw]
        else:
            candidates = [primary_finding]

    return candidates


def _finding_summary_table(findings: List[Dict[str, Any]]) -> str:
    if not findings:
        return "<p>No finding summary available.</p>"

    rows = []
    for f in findings:
        evidence = f.get("evidence") or ""
        reflected = _evidence_get(evidence, "reflection", f.get("reflected", "-"))
        verification = _evidence_get(evidence, "verification", f.get("verification", "-"))
        url = f.get("url") or f.get("target_url") or "-"
        payload = _short_payload(f.get("payload") or "-")
        rows.append(
            "<tr>"
            f"<td>{_html(f.get('id') or f.get('finding_id') or '-')}</td>"
            f"<td>{_html(f.get('severity') or '-')}</td>"
            f"<td>{_html(f.get('confidence') or '-')}</td>"
            f"<td>{_html(_compact_url(url))}</td>"
            f"<td>{_html(f.get('parameter') or '-')}</td>"
            f'<td class="payload-cell">{_code_inline(payload)}</td>'
            f"<td>{_html(verification)}</td>"
            f"<td>{_html(reflected)}</td>"
            "</tr>"
        )

    return """
    <table class="finding-summary">
      <thead>
        <tr>
          <th>ID</th><th>Severity</th><th>Confidence</th><th>Target Path</th>
          <th>Param</th><th>Payload</th><th>Verification</th><th>Reflected</th>
        </tr>
      </thead>
      <tbody>
    """ + "\n".join(rows) + """
      </tbody>
    </table>
    """


