def _safe(value: Any, default: str = "-") -> str:
    if value is None or value == "":
        return default
    return str(value)


def _as_dict(value: Any) -> Dict[str, Any]:
    return value if isinstance(value, dict) else {}


def _as_list(value: Any) -> List[Any]:
    if value is None:
        return []
    if isinstance(value, list):
        return value
    return [value]


def _truthy_text(value: Any) -> str:
    if isinstance(value, bool):
        return "true" if value else "false"
    return _safe(value)


def _truncate(value: Any, limit: int = 1600) -> str:
    text = _safe(value, "")
    if len(text) <= limit:
        return text
    return text[:limit] + "\n... (truncated)"


def _html(value: Any) -> str:
    return escape(_safe(value))


def _evidence_get(evidence: Any, key: str, default: Any = None) -> Any:
    if isinstance(evidence, dict):
        return evidence.get(key, default)

    text = "" if evidence is None else str(evidence)
    lower = text.lower()

    if key in ("reflection", "reflected", "reflection_detected"):
        markers = [
            "reflected in http response",
            "payload reflected",
            "payload already present",
            "direct_url_payload_reflected",
            "verification=payload_reflected",
            "verification=direct_url_payload_reflected",
            "without clear output encoding",
            "reflected_value=",
            "was reflected",
        ]
        return any(marker in lower for marker in markers)

    if key in ("reflected_value", "payload"):
        for marker in ("reflected_value=", "payload="):
            if marker in text:
                return text.split(marker, 1)[1].split(";", 1)[0].strip()
        return default

    if key in ("verification", "verified"):
        if "direct_url_payload_reflected" in text:
            return "direct_url_payload_reflected"
        if "verification=payload_reflected" in text or "payload reflected" in lower:
            return "payload_reflected"
        if "reflected in http response" in lower:
            return "payload_reflected"
        return default

    if key in ("snippet", "response_snippet", "body", "raw"):
        return text if text else default

    return default


def _extract_reflection_info(finding: Dict[str, Any]) -> Dict[str, Any]:
    direct = _as_dict(finding.get("reflection_detected"))
    if direct:
        return direct

    evidence = finding.get("evidence")
    payload = finding.get("payload")
    return {
        "detected": _evidence_get(evidence, "reflection", False),
        "reflected_value": _evidence_get(evidence, "reflected_value", payload or "-"),
        "verification": _evidence_get(evidence, "verification", "payload_reflected"),
        "encoded": False,
    }


def _get_agent_response(finding: Dict[str, Any]) -> Dict[str, Any]:
    agent = _as_dict(finding.get("agent_response"))
    if agent:
        return agent

    # fallback: some normalizers flatten these fields at top-level
    keys = [
        "task",
        "should_run",
        "context_known",
        "fallback",
        "reason",
        "selected_plugin",
        "severity",
        "confidence",
    ]
    return {k: finding.get(k) for k in keys if k in finding}


def _get_rag_hints(finding: Dict[str, Any]) -> Dict[str, Any]:
    hints = _as_dict(finding.get("rag_hints"))
    if hints:
        return hints

    hints = {}
    for key in ("official_references", "recommended_docs", "query", "rag_query"):
        if key in finding:
            hints[key] = finding.get(key)
    return hints


def _normalize_official_reference_key(value: Any) -> Optional[str]:
    text = _safe(value, "").strip()
    if not text:
        return None

    lowered = text.lower()
    if "owasp" in lowered or "output encoding" in lowered or "xss prevention" in lowered:
        return "OWASP XSS Prevention Cheat Sheet"
    if "cwe-79" in lowered or "cwe 79" in lowered or "definitions/79" in lowered:
        return "CWE-79"
    if "mdn" in lowered or "mozilla" in lowered:
        return "MDN XSS"
    if "portswigger" in lowered or "reflected xss" in lowered:
        return "PortSwigger Reflected XSS"
    return text if text in OFFICIAL_REFERENCE_CATALOG else None


def _is_external_context(ctx: Dict[str, Any]) -> bool:
    source_type = _safe(ctx.get("source_type"), "").lower()
    retriever = _safe(ctx.get("retriever"), "").lower()
    source = _safe(ctx.get("source") or ctx.get("path"), "").lower()

    return (
        "external" in source_type
        or "official" in retriever
        or "owasp" in source
        or "cwe.mitre" in source
        or "developer.mozilla" in source
        or "mozilla" in source
        or "portswigger" in source
    )


def _split_contexts(rag_contexts: List[Dict[str, Any]]) -> Tuple[List[Dict[str, Any]], List[Dict[str, Any]]]:
    internal: List[Dict[str, Any]] = []
    external: List[Dict[str, Any]] = []

    for ctx in rag_contexts:
        if not isinstance(ctx, dict):
            continue
        if _is_external_context(ctx):
            external.append(ctx)
        else:
            internal.append(ctx)

    return internal, external


def _build_external_reference_fallback(finding: Dict[str, Any]) -> List[Dict[str, Any]]:
    hints = _get_rag_hints(finding)
    raw_candidates: List[Any] = []

    raw_candidates.extend(_as_list(hints.get("official_references")))
    raw_candidates.extend(_as_list(finding.get("official_references")))

    for doc in _as_list(hints.get("recommended_docs")) + _as_list(finding.get("recommended_docs")):
        mapped = RECOMMENDED_DOC_TO_REFERENCE_KEY.get(_safe(doc, ""))
        if mapped:
            raw_candidates.append(mapped)

    # For XSS findings, add a sane default official reference set if no hint exists.
    vuln_type = _safe(finding.get("vuln_type") or finding.get("vulnerability_type") or finding.get("source_plugin"), "").lower()
    if not raw_candidates and "xss" in vuln_type:
        raw_candidates.extend([
            "OWASP XSS Prevention Cheat Sheet",
            "CWE-79",
            "MDN XSS",
            "PortSwigger Reflected XSS",
        ])

    refs: List[Dict[str, Any]] = []
    seen = set()

    for item in raw_candidates:
        key = _normalize_official_reference_key(item)
        if not key or key in seen:
            continue
        seen.add(key)
        catalog_item = OFFICIAL_REFERENCE_CATALOG.get(key)
        if catalog_item:
            refs.append(
                {
                    "title": catalog_item["title"],
                    "source": catalog_item["source"],
                    "source_type": "external_official_catalog_fallback",
                    "retriever": "official_catalog_fallback",
                    "score": "fallback",
                    "content": catalog_item["summary"],
                }
            )

    return refs


