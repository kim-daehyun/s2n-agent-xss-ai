    finding: Dict[str, Any],
    rag_contexts: Optional[List[Dict[str, Any]]] = None,
    pdf_path: str = DEFAULT_PDF_PATH,
) -> str:
    return generate_xss_pdf_report(finding, rag_contexts, pdf_path)
