def _p(text: Any, style: ParagraphStyle) -> Paragraph:
    return Paragraph(_html(text).replace("\n", "<br/>"), style)


def _table(rows: List[Tuple[str, Any]], styles: Dict[str, ParagraphStyle], col_widths=None) -> Table:
    data = []
    for key, value in rows:
        data.append([
            Paragraph(f"<b>{_html(key)}</b>", styles["small"]),
            Paragraph(_html(_truthy_text(value)).replace("\n", "<br/>") or "-", styles["small"]),
        ])

    if col_widths is None:
        col_widths = [45 * mm, 125 * mm]

    table = Table(data, colWidths=col_widths, hAlign="LEFT")
    table.setStyle(
        TableStyle(
            [
                ("BACKGROUND", (0, 0), (0, -1), colors.HexColor("#e5e7eb")),
                ("GRID", (0, 0), (-1, -1), 0.4, colors.HexColor("#d1d5db")),
                ("VALIGN", (0, 0), (-1, -1), "TOP"),
                ("LEFTPADDING", (0, 0), (-1, -1), 7),
                ("RIGHTPADDING", (0, 0), (-1, -1), 7),
                ("TOPPADDING", (0, 0), (-1, -1), 6),
                ("BOTTOMPADDING", (0, 0), (-1, -1), 6),
            ]
        )
    )
    return table


def _pre(text: Any, styles: Dict[str, ParagraphStyle], max_chars: int = 1800) -> Preformatted:
    content = _truncate(text, max_chars)
    return Preformatted(content, styles["small"], maxLineLength=110)


def _section_title(story: List[Any], title: str, styles: Dict[str, ParagraphStyle]) -> None:
    story.append(Spacer(1, 5))
    story.append(Paragraph(title, styles["h1"]))
    story.append(Spacer(1, 4))


def _render_executive_summary(story: List[Any], finding: Dict[str, Any], styles: Dict[str, ParagraphStyle]) -> None:
    _section_title(story, "1. Executive Summary", styles)
    story.append(
        _p(
            "This report was generated from an actual S2N scan result and describes a confirmed XSS finding.",
            styles["body"],
        )
    )
    story.append(
        _table(
            [
                ("Finding", finding.get("title") or "Reflected Cross-Site Scripting Detected"),
                ("Severity", finding.get("severity") or "HIGH"),
                ("Confidence", finding.get("confidence") or "FIRM"),
                ("Target URL", finding.get("target_url") or finding.get("url")),
                ("Affected Parameter", finding.get("parameter")),
                ("Payload", finding.get("payload")),
                ("Source Scanner", finding.get("source_scanner") or "s2n"),
                ("Source Plugin", finding.get("source_plugin") or "xss"),
            ],
            styles,
        )
    )


def _render_finding_detail(story: List[Any], finding: Dict[str, Any], styles: Dict[str, ParagraphStyle]) -> None:
    reflection = _extract_reflection_info(finding)
    risk = _as_dict(finding.get("risk"))

    _section_title(story, "2. Finding Detail", styles)
    story.append(
        _table(
            [
                ("ID", finding.get("id") or finding.get("finding_id")),
                ("Title", finding.get("title")),
                ("Vulnerability Type", finding.get("vuln_type") or finding.get("vulnerability_type") or "XSS"),
                ("XSS Type", finding.get("xss_type") or "reflected"),
                ("CWE", finding.get("cwe") or "CWE-79"),
                ("OWASP Category", finding.get("owasp_category") or "Injection / Cross-Site Scripting"),
                ("HTTP Method", finding.get("method") or finding.get("http_method")),
                ("Parameter", finding.get("parameter")),
                ("Reflection Detected", reflection.get("detected")),
                ("Reflected Value", reflection.get("reflected_value")),
                ("Verification", reflection.get("verification")),
                ("Risk Score", risk.get("risk_score")),
                ("Likelihood", risk.get("likelihood")),
                ("Impact", risk.get("impact")),
            ],
            styles,
        )
    )
    story.append(Spacer(1, 8))
    story.append(Paragraph("Description", styles["h2"]))
    story.append(
        _p(
            finding.get("description")
            or "User-controlled input was reflected in the HTTP response without clear output encoding.",
            styles["body"],
        )
    )


def _render_evidence(story: List[Any], finding: Dict[str, Any], styles: Dict[str, ParagraphStyle]) -> None:
    evidence = finding.get("evidence")
    response_snippet = finding.get("response_snippet") or _evidence_get(evidence, "response_snippet", evidence)

    _section_title(story, "3. Evidence", styles)
    story.append(Paragraph("Raw Evidence", styles["h2"]))
    story.append(_pre(evidence, styles, 1800))
    story.append(Spacer(1, 8))
    story.append(Paragraph("Response Snippet", styles["h2"]))
    story.append(_pre(response_snippet, styles, 1800))


def _render_agent_judgement(story: List[Any], finding: Dict[str, Any], styles: Dict[str, ParagraphStyle]) -> None:
    agent = _get_agent_response(finding)
    _section_title(story, "4. XSSAgent Judgement", styles)
    story.append(
        _table(
            [
                ("Task", agent.get("task") or "selection"),
                ("Should Run", agent.get("should_run")),
                ("Context Known", agent.get("context_known")),
                ("Selected Plugin", agent.get("selected_plugin") or finding.get("source_plugin") or "xss"),
                ("Severity", agent.get("severity") or finding.get("severity")),
                ("Confidence", agent.get("confidence") or finding.get("confidence")),
                ("Fallback", agent.get("fallback")),
                ("Reason", agent.get("reason") or "S2N detected reflected XSS payload in HTTP response."),
            ],
            styles,
        )
    )


def _render_risk_and_remediation(story: List[Any], finding: Dict[str, Any], styles: Dict[str, ParagraphStyle]) -> None:
    risk = _as_dict(finding.get("risk"))
    _section_title(story, "5. Risk & Remediation", styles)
    story.append(Paragraph("Risk", styles["h2"]))
    story.append(
        _table(
            [
                ("Severity", finding.get("severity") or "HIGH"),
                ("Risk Score", risk.get("risk_score")),
                ("Likelihood", risk.get("likelihood")),
                ("Impact", risk.get("impact")),
                ("Business Impact", risk.get("business_impact")),
            ],
            styles,
        )
    )
    story.append(Spacer(1, 8))
    story.append(Paragraph("Recommended Remediation", styles["h2"]))
    remediation = [
        "Apply context-aware output encoding before inserting user-controlled input into HTML.",
        "Validate and constrain user input on the server side.",
        "Avoid directly reflecting raw request parameters into responses.",
        "Use safe DOM APIs such as textContent instead of innerHTML where possible.",
        "Add Content Security Policy as a defense-in-depth control.",
        "Re-test the affected parameter with the same payload after remediation.",
    ]
    for idx, item in enumerate(remediation, start=1):
        story.append(_p(f"{idx}. {item}", styles["body"]))


def _render_internal_contexts(
    story: List[Any],
    contexts: List[Dict[str, Any]],
    styles: Dict[str, ParagraphStyle],
) -> None:
    _section_title(story, "6. Internal Knowledge Retrieved by ChromaDB", styles)
    if not contexts:
        story.append(_p("No internal RAG context was retrieved.", styles["body"]))
        return

    for idx, ctx in enumerate(contexts, start=1):
        title = ctx.get("title") or ctx.get("name") or f"Internal Context {idx}"
        source = ctx.get("source") or ctx.get("path") or "-"
        retriever = ctx.get("retriever") or "-"
        score = ctx.get("score") or "-"
        content = ctx.get("content") or ctx.get("text") or ctx.get("chunk") or ""
        story.append(Paragraph(f"6.{idx} {escape(_safe(title))}", styles["h2"]))
        story.append(_table([("Source", source), ("Retriever", retriever), ("Score", score)], styles))
        story.append(Spacer(1, 4))
        story.append(_pre(content, styles, 1100))
        story.append(Spacer(1, 8))


def _render_external_references(
    story: List[Any],
    finding: Dict[str, Any],
    external_contexts: List[Dict[str, Any]],
    styles: Dict[str, ParagraphStyle],
) -> None:
    _section_title(story, "7. External Official References", styles)
    story.append(
        _p(
            "This section contains official reference matches from OWASP, CWE, MDN, and PortSwigger. "
            "If no live external retriever result is available, the report falls back to official catalog hints "
            "derived from the normalized finding.",
            styles["note"],
        )
    )

    refs = external_contexts[:] if external_contexts else _build_external_reference_fallback(finding)

    if not refs:
        story.append(_p("No external official reference was matched.", styles["body"]))
        return

    for idx, ref in enumerate(refs, start=1):
        title = ref.get("title") or ref.get("name") or f"External Reference {idx}"
        source = ref.get("source") or ref.get("path") or "-"
        retriever = ref.get("retriever") or ref.get("source_type") or "official_reference"
        score = ref.get("score") or "-"
        content = ref.get("content") or ref.get("text") or ref.get("summary") or ""
        story.append(Paragraph(f"7.{idx} {escape(_safe(title))}", styles["h2"]))
        story.append(
            _table(
                [
                    ("Source", source),
                    ("Retriever", retriever),
                    ("Score", score),
                ],
                styles,
            )
        )
        story.append(Spacer(1, 4))
        story.append(_p(content, styles["body"]))
        story.append(Spacer(1, 8))


def _render_retest(story: List[Any], finding: Dict[str, Any], styles: Dict[str, ParagraphStyle]) -> None:
    _section_title(story, "8. Retest Recommendation", styles)
    story.append(
        _p(
            "Re-run the S2N XSS plugin against the affected endpoint after remediation.",
            styles["body"],
        )
    )
    story.append(
        _table(
            [
                ("Target URL", finding.get("target_url") or finding.get("url")),
                ("Parameter", finding.get("parameter")),
                ("Payload", finding.get("payload")),
                ("Expected Secure Result", "The payload should be encoded or rejected and must not execute as JavaScript."),
            ],
            styles,
        )
    )


def generate_xss_pdf_report(
    finding: Dict[str, Any],
    rag_contexts: Optional[List[Dict[str, Any]]] = None,
    pdf_path: str = DEFAULT_PDF_PATH,
) -> str:
    finding = finding or {}
    rag_contexts = [ctx for ctx in _as_list(rag_contexts) if isinstance(ctx, dict)]
    internal_contexts, external_contexts = _split_contexts(rag_contexts)

    output = Path(pdf_path)
    output.parent.mkdir(parents=True, exist_ok=True)

    doc = SimpleDocTemplate(
        str(output),
        pagesize=A4,
        rightMargin=16 * mm,
        leftMargin=16 * mm,
        topMargin=14 * mm,
        bottomMargin=14 * mm,
        title="S2N XSS Security Report",
        author="S2N XSSAgent",
    )

    styles = _styles()
    story: List[Any] = []
    story.append(Paragraph("S2N XSS Security Report", styles["title"]))
    story.append(_p(f"Generated at: {datetime.utcnow().isoformat()}Z", styles["small"]))
    story.append(Spacer(1, 10))

    _render_executive_summary(story, finding, styles)
    _render_finding_detail(story, finding, styles)
    _render_evidence(story, finding, styles)
    _render_agent_judgement(story, finding, styles)
    _render_risk_and_remediation(story, finding, styles)
    _render_internal_contexts(story, internal_contexts, styles)
    _render_external_references(story, finding, external_contexts, styles)
    _render_retest(story, finding, styles)

    doc.build(story)
    return str(output)


