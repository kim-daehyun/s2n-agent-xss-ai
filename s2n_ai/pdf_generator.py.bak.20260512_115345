from __future__ import annotations

from pathlib import Path
from typing import Any, Dict, List, Tuple
from html import escape
from datetime import datetime
import re


DEFAULT_PDF_PATH = "reports/generated/dvwa_s2n_xss_report.pdf"


def _safe(value: Any, default: str = "-") -> str:
    if value is None:
        return default
    if isinstance(value, bool):
        return "true" if value else "false"
    text = str(value)
    if text == "":
        return default
    return text


def _as_list(value: Any) -> List[Any]:
    if value is None:
        return []
    if isinstance(value, list):
        return value
    if isinstance(value, tuple):
        return list(value)
    return [value]


def _clean_text(value: Any, limit: int | None = None) -> str:
    text = "" if value is None else str(value)
    text = text.replace("\r\n", "\n").replace("\r", "\n").replace("\t", "    ")
    text = text.replace("\x00", "")
    text = text.replace("■", "")
    text = re.sub(r"\n{3,}", "\n\n", text)
    text = re.sub(r"[ \f\v]+", " ", text)
    text = "\n".join(line.rstrip() for line in text.splitlines()).strip()
    if limit and len(text) > limit:
        text = text[:limit].rstrip() + "\n... [truncated]"
    return text


def _clean_markdown(value: Any, limit: int | None = None) -> str:
    text = _clean_text(value, limit=limit)
    lines: List[str] = []
    for line in text.splitlines():
        stripped = line.strip()
        # PDF에는 Markdown heading 기호가 그대로 보이면 지저분하므로 제거
        stripped = re.sub(r"^#{1,6}\s+", "", stripped)
        # markdown bullet은 그대로 보이되, 중복 공백만 정리
        lines.append(stripped)
    return "\n".join(lines).strip()


def _html_text(value: Any, default: str = "-") -> str:
    return escape(_safe(value, default))


def _pre(value: Any, limit: int = 1600) -> str:
    text = _clean_text(value, limit=limit)
    if not text:
        text = "-"
    return f"<pre>{escape(text)}</pre>"


def _table(rows: List[Tuple[str, Any]]) -> str:
    body = []
    for key, value in rows:
        body.append(
            "<tr>"
            f"<th>{escape(str(key))}</th>"
            f"<td>{_html_text(value)}</td>"
            "</tr>"
        )
    return '<table class="kv">' + "\n".join(body) + "</table>"


def _evidence_get(evidence: Any, key: str, default: Any = None) -> Any:
    if isinstance(evidence, dict):
        return evidence.get(key, default)

    text = "" if evidence is None else str(evidence)
    lower = text.lower()

    if key in ("reflection", "reflected", "reflection_detected"):
        markers = [
            "reflected in http response",
            "payload reflected",
            "payload already present",
            "direct_url_payload_reflected",
            "verification=payload_reflected",
            "verification=direct_url_payload_reflected",
            "without clear output encoding",
            "reflected_value=",
            "was reflected",
        ]
        return any(marker in lower for marker in markers)

    if key in ("reflected_value", "payload"):
        for marker in ("reflected_value=", "payload="):
            if marker in text:
                return text.split(marker, 1)[1].split(";", 1)[0].strip()
        return default

    if key in ("verification", "verified"):
        if "direct_url_payload_reflected" in text:
            return "direct_url_payload_reflected"
        if "verification=payload_reflected" in text or "payload reflected" in lower:
            return "payload_reflected"
        return default

    if key in ("snippet", "response_snippet", "body", "raw"):
        if "snippet=" in text:
            return text.split("snippet=", 1)[1].strip()
        return text if text else default

    return default


def _get_report_field(finding: Dict[str, Any], key: str, default: Any = None) -> Any:
    report_fields = finding.get("report_fields") or {}
    if isinstance(report_fields, dict) and key in report_fields:
        return report_fields.get(key, default)
    if key in finding:
        return finding.get(key, default)
    raw = finding.get("raw_result") or {}
    if isinstance(raw, dict):
        return raw.get(key, default)
    return default


def _risk(finding: Dict[str, Any], key: str, default: Any = None) -> Any:
    risk = finding.get("risk") or {}
    if isinstance(risk, dict):
        return risk.get(key, default)
    return default


def _agent(finding: Dict[str, Any], key: str, default: Any = None) -> Any:
    agent_response = finding.get("agent_response") or {}
    if isinstance(agent_response, dict):
        return agent_response.get(key, default)
    return default


def _normalize_rag_contexts(raw: Any) -> List[Dict[str, Any]]:
    contexts: List[Dict[str, Any]] = []

    if raw is None:
        return contexts

    # retriever 결과가 {"internal": [...], "external": [...]}처럼 오는 경우 처리
    if isinstance(raw, dict):
        if "internal" in raw or "external" in raw:
            for item in _as_list(raw.get("internal")) + _as_list(raw.get("external")):
                if isinstance(item, dict):
                    contexts.append(item)
            return contexts
        # 단일 context dict
        return [raw]

    for item in _as_list(raw):
        if isinstance(item, dict):
            contexts.append(item)
        elif item is not None:
            contexts.append({"title": "Retrieved Context", "content": str(item)})

    return contexts


def _context_source_type(ctx: Dict[str, Any]) -> str:
    source_type = str(ctx.get("source_type") or ctx.get("type") or "").lower()
    retriever = str(ctx.get("retriever") or "").lower()
    source = str(ctx.get("source") or ctx.get("path") or ctx.get("url") or "").lower()

    if source_type in ("external_official", "official", "external"):
        return "external"
    if retriever in ("external_web", "official_web", "official_catalog", "official_catalog_fallback"):
        return "external"
    if any(x in source for x in ("owasp.org", "cwe.mitre.org", "developer.mozilla.org", "portswigger.net")):
        return "external"
    return "internal"


def _context_content(ctx: Dict[str, Any]) -> str:
    return _clean_markdown(
        ctx.get("content")
        or ctx.get("text")
        or ctx.get("page_content")
        or ctx.get("snippet")
        or ctx.get("body")
        or "",
        limit=2200,
    )


def _context_title(ctx: Dict[str, Any], index: int) -> str:
    raw_title = _safe(ctx.get("title") or ctx.get("name") or "", "")
    content = _context_content(ctx).lower()

    # 같은 문서에서 나온 chunk도 리포트에서는 의미 단위로 재분류
    if "recommended fix" in content:
        return "Recommended Fix Summary"
    if "html body context" in content or "html entity encoding" in content:
        return "HTML Body Context Guidance"
    if "reflected xss" in content or "user-controlled input is included" in content:
        return "Reflected XSS Explanation"

    if raw_title:
        return raw_title
    return f"Retrieved Security Context {index}"


def _dedupe_contexts(contexts: List[Dict[str, Any]], limit: int = 3) -> List[Dict[str, Any]]:
    seen = set()
    result = []
    for ctx in contexts:
        content = _context_content(ctx)
        title = _context_title(ctx, len(result) + 1)
        key = (title.lower(), content[:180].lower())
        if key in seen:
            continue
        seen.add(key)
        copied = dict(ctx)
        copied["_render_title"] = title
        copied["_render_content"] = content
        result.append(copied)
        if len(result) >= limit:
            break
    return result


def _official_reference_catalog() -> Dict[str, Dict[str, str]]:
    return {
        "owasp": {
            "title": "OWASP Cross Site Scripting Prevention Cheat Sheet",
            "source": "https://cheatsheetseries.owasp.org/cheatsheets/Cross_Site_Scripting_Prevention_Cheat_Sheet.html",
            "summary": "OWASP recommends context-aware output encoding, safe HTML handling, strict input validation, and Content Security Policy as defense-in-depth for XSS prevention.",
        },
        "cwe-79": {
            "title": "CWE-79: Improper Neutralization of Input During Web Page Generation",
            "source": "https://cwe.mitre.org/data/definitions/79.html",
            "summary": "CWE-79 describes XSS as improper neutralization of user-controlled input during web page generation, allowing script execution in a user's browser.",
        },
        "mdn": {
            "title": "MDN Web Docs: Cross-site scripting",
            "source": "https://developer.mozilla.org/en-US/docs/Web/Security/Attacks/XSS",
            "summary": "MDN explains XSS attack patterns and recommends output encoding, safe DOM APIs, sanitization, and CSP to reduce script injection risk.",
        },
        "portswigger": {
            "title": "PortSwigger Web Security Academy: Reflected XSS",
            "source": "https://portswigger.net/web-security/cross-site-scripting/reflected",
            "summary": "PortSwigger describes reflected XSS as user input immediately returned in an unsafe HTTP response and recommends context-specific validation and encoding.",
        },
    }


def _official_refs_from_finding(finding: Dict[str, Any], external_contexts: List[Dict[str, Any]]) -> List[Dict[str, Any]]:
    # 실제 external retriever 결과가 있으면 우선 사용
    if external_contexts:
        refs = []
        for ctx in external_contexts:
            refs.append({
                "title": ctx.get("title") or ctx.get("name") or "External Official Reference",
                "source": ctx.get("source") or ctx.get("url") or ctx.get("path") or "-",
                "retriever": ctx.get("retriever") or "external_official",
                "score": ctx.get("score") or ctx.get("similarity") or "-",
                "summary": _context_content(ctx),
            })
        return refs

    # live 외부 RAG가 없는 경우: normalizer의 공식 reference hint 기반 fallback
    hints = finding.get("rag_hints") or {}
    hint_text = " ".join([
        " ".join(_as_list(hints.get("official_references"))),
        " ".join(_as_list(hints.get("recommended_docs"))),
        _safe(hints.get("cwe"), ""),
        _safe(finding.get("cwe"), ""),
        _safe(finding.get("vuln_type"), ""),
        _safe(finding.get("xss_type"), ""),
    ]).lower()

    catalog = _official_reference_catalog()
    keys = []

    if "owasp" in hint_text or "xss" in hint_text:
        keys.append("owasp")
    if "cwe-79" in hint_text or "cwe" in hint_text or "xss" in hint_text:
        keys.append("cwe-79")
    if "mdn" in hint_text or "xss" in hint_text:
        keys.append("mdn")
    if "portswigger" in hint_text or "reflected" in hint_text or "xss" in hint_text:
        keys.append("portswigger")

    if not keys:
        keys = ["owasp", "cwe-79", "mdn", "portswigger"]

    refs = []
    for key in dict.fromkeys(keys):
        item = catalog[key]
        refs.append({
            "title": item["title"],
            "source": item["source"],
            "retriever": "official_catalog_fallback",
            "score": "fallback",
            "summary": item["summary"],
        })
    return refs


def _render_internal_contexts(contexts: List[Dict[str, Any]]) -> str:
    if not contexts:
        return "<p>No internal knowledge context was retrieved.</p>"

    chunks = []
    for idx, ctx in enumerate(_dedupe_contexts(contexts, limit=3), start=1):
        title = ctx.get("_render_title") or _context_title(ctx, idx)
        content = ctx.get("_render_content") or _context_content(ctx)

        chunks.append(f"""
        <section class="avoid-break rag-card">
          <h3>6.{idx} {escape(title)}</h3>
          {_table([
              ("Source", ctx.get("source") or ctx.get("path") or "-"),
              ("Retriever", ctx.get("retriever") or "-"),
              ("Retrieval Score", ctx.get("score") or ctx.get("similarity") or "-"),
          ])}
          <div class="context-text">{_render_text_with_bullets(content)}</div>
        </section>
        """)
    return "\n".join(chunks)


def _render_external_refs(refs: List[Dict[str, Any]]) -> str:
    if not refs:
        return "<p>No official reference mapping was available.</p>"

    chunks = []
    for idx, ref in enumerate(refs, start=1):
        chunks.append(f"""
        <section class="avoid-break ref-card">
          <h3>7.{idx} {escape(_safe(ref.get("title")))}</h3>
          {_table([
              ("Source", ref.get("source") or "-"),
              ("Source Mode", ref.get("retriever") or "-"),
              ("Score", ref.get("score") or "-"),
          ])}
          <p>{escape(_clean_text(ref.get("summary"), limit=900))}</p>
        </section>
        """)
    return "\n".join(chunks)


def _render_text_with_bullets(text: str) -> str:
    if not text:
        return "<p>-</p>"

    parts = []
    in_ul = False

    for line in text.splitlines():
        stripped = line.strip()
        if not stripped:
            if in_ul:
                parts.append("</ul>")
                in_ul = False
            continue

        if stripped.startswith("- "):
            if not in_ul:
                parts.append("<ul>")
                in_ul = True
            parts.append(f"<li>{escape(stripped[2:].strip())}</li>")
        else:
            if in_ul:
                parts.append("</ul>")
                in_ul = False
            parts.append(f"<p>{escape(stripped)}</p>")

    if in_ul:
        parts.append("</ul>")

    return "\n".join(parts)


