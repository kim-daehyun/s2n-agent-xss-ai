def generate_xss_pdf_report(
    finding: Dict[str, Any],
    rag_contexts: List[Dict[str, Any]] | Dict[str, Any] | None = None,
    pdf_path: str = DEFAULT_PDF_PATH,
    output_path: str | None = None,
    **_: Any,
) -> str:
    """
    Generate a portfolio-ready XSS PDF report.

    Compatible with the existing pipeline:
      generate_xss_pdf_report(normalized_finding, rag_contexts)
      generate_xss_pdf_report(finding=..., rag_contexts=..., pdf_path=...)
      generate_xss_pdf_report(..., output_path=...)
    """
    finding = finding or {}
    pdf_path = output_path or pdf_path or DEFAULT_PDF_PATH

    evidence = _get_report_field(finding, "evidence", finding.get("evidence"))
    response_snippet = _get_report_field(
        finding,
        "response_snippet",
        _evidence_get(evidence, "response_snippet", ""),
    )

    all_contexts = _normalize_rag_contexts(rag_contexts)
    internal_contexts = [c for c in all_contexts if _context_source_type(c) == "internal"]
    external_contexts = [c for c in all_contexts if _context_source_type(c) == "external"]
    official_refs = _official_refs_from_finding(finding, external_contexts)

    title = _get_report_field(finding, "title", "Reflected Cross-Site Scripting Detected")
    severity = _get_report_field(finding, "severity", finding.get("severity", "HIGH"))
    confidence = _get_report_field(finding, "confidence", finding.get("confidence", "FIRM"))
    target_url = _get_report_field(finding, "target_url", finding.get("url"))
    parameter = _get_report_field(finding, "parameter", "-")
    payload = _get_report_field(finding, "payload", "-")
    reflected_value = _get_report_field(finding, "reflected_value", _evidence_get(evidence, "reflected_value", "-"))
    verification = _get_report_field(finding, "verification", _evidence_get(evidence, "verification", "-"))
    reflected = _get_report_field(finding, "reflection_detected", _evidence_get(evidence, "reflection", False))

    html = f"""<!doctype html>
<html>
<head>
  <meta charset="utf-8">
  <title>S2N XSS Security Report</title>
  <style>{_css()}</style>
</head>
<body>
  <h1>S2N XSS Security Report</h1>
  <p class="muted">Generated at: {escape(datetime.utcnow().isoformat())}Z</p>

  <h2>1. Executive Summary</h2>
  <p>This report was generated from an actual S2N scan result and describes a confirmed reflected XSS finding.</p>
  {_table([
      ("Finding", title),
      ("Severity", severity),
      ("Confidence", confidence),
      ("Target URL", target_url),
      ("Affected Parameter", parameter),
      ("Payload", payload),
      ("Source Scanner", finding.get("source_scanner") or "s2n"),
      ("Source Plugin", finding.get("source_plugin") or "xss"),
  ])}

  <h2>2. Finding Detail</h2>
  {_table([
      ("ID", finding.get("id") or finding.get("finding_id") or "-"),
      ("Title", title),
      ("Vulnerability Type", finding.get("vuln_type") or finding.get("vulnerability_type") or "XSS"),
      ("XSS Type", finding.get("xss_type") or "reflected"),
      ("CWE", finding.get("cwe") or "CWE-79"),
      ("OWASP Category", finding.get("owasp_category") or "Injection / Cross-Site Scripting"),
      ("HTTP Method", _get_report_field(finding, "method", _get_report_field(finding, "http_method", "GET"))),
      ("Parameter", parameter),
      ("Injection Context", finding.get("injection_context") or "-"),
      ("Reflection Detected", reflected),
      ("Reflected Value", reflected_value),
      ("Verification", verification),
      ("Risk Score", _risk(finding, "risk_score", "85")),
      ("Likelihood", _risk(finding, "likelihood", "High")),
      ("Impact", _risk(finding, "impact", "High")),
  ])}

  <h3>Description</h3>
  <p>{escape(_clean_text(finding.get("description") or "User-controlled input was reflected in the HTTP response without proper output encoding.", limit=900))}</p>

  <h2>3. Evidence</h2>
  <h3>Raw Evidence</h3>
  {_pre(evidence, limit=1800)}
  <h3>Response Snippet</h3>
  {_pre(response_snippet, limit=1400)}

  <h2>4. XSSAgent Judgement</h2>
  {_table([
      ("Task", _agent(finding, "task", "-")),
      ("Should Run", _agent(finding, "should_run", "-")),
      ("Context Known", _agent(finding, "context_known", "-")),
      ("Selected Plugin", _agent(finding, "selected_plugin", "-")),
      ("Severity", _agent(finding, "severity", severity)),
      ("Confidence", _agent(finding, "confidence", confidence)),
      ("Fallback", _agent(finding, "fallback", "-")),
      ("Reason", _agent(finding, "reason", "-")),
  ])}

  <h2>5. Risk & Remediation</h2>
  <h3>Risk</h3>
  {_table([
      ("Severity", severity),
      ("Risk Score", _risk(finding, "risk_score", "85")),
      ("Likelihood", _risk(finding, "likelihood", "High")),
      ("Impact", _risk(finding, "impact", "High")),
      ("Business Impact", _risk(finding, "business_impact", "An attacker may execute arbitrary JavaScript in a victim browser, steal session data, perform actions as the user, or manipulate page content.")),
  ])}

  <h3>Scoring Basis</h3>
  <ul>
    <li>Severity is high because browser-executable JavaScript was reflected in the response.</li>
    <li>Confidence is firm because the payload and reflected value were verified in the HTTP response.</li>
    <li>Likelihood is high when user-controlled input is returned without context-aware output encoding.</li>
    <li>Impact is high because reflected script execution can lead to session theft, user action abuse, or page manipulation.</li>
  </ul>

  <h3>Recommended Remediation</h3>
  <ol>
    <li>Apply context-aware output encoding before inserting user-controlled input into HTML.</li>
    <li>Validate and constrain user input on the server side.</li>
    <li>Avoid directly reflecting raw request parameters into responses.</li>
    <li>Use safe DOM APIs such as <code>textContent</code> instead of <code>innerHTML</code> where possible.</li>
    <li>Add Content Security Policy as a defense-in-depth control.</li>
    <li>Re-test the affected parameter with the same payload after remediation.</li>
  </ol>

  <h2>6. Internal Knowledge Retrieved by ChromaDB</h2>
  {_render_internal_contexts(internal_contexts)}

  <h2>7. Official Reference Mapping</h2>
  <div class="notice">
    This section shows official reference mapping. If a live external web retriever is not available, references are rendered from the normalized finding's official catalog hints.
  </div>
  {_render_external_refs(official_refs)}

  <h2>8. Retest Recommendation</h2>
  <p>Re-run the S2N XSS plugin against the affected endpoint after remediation.</p>
  {_table([
      ("Target URL", target_url),
      ("Parameter", parameter),
      ("Payload", payload),
      ("Expected Secure Result", "The payload should be encoded or rejected and must not execute as JavaScript."),
  ])}

  <h3>Retest Steps</h3>
  <ol>
    <li>Send the same GET request to the affected endpoint with the original payload.</li>
    <li>Verify that <code>&lt;</code> and <code>&gt;</code> are encoded as <code>&amp;lt;</code> and <code>&amp;gt;</code>, or that the input is rejected.</li>
    <li>Open the response in a browser and confirm that no JavaScript alert or script execution occurs.</li>
    <li>Re-run the S2N XSS plugin and confirm that the finding count for this endpoint is zero.</li>
  </ol>
</body>
</html>
"""

    out = Path(pdf_path)
    out.parent.mkdir(parents=True, exist_ok=True)

    try:
        from weasyprint import HTML
        HTML(string=html, base_url=str(Path.cwd())).write_pdf(str(out))
    except Exception as exc:
        # PDF engine 문제가 생기면 HTML을 남겨 디버깅 가능하게 함
        html_path = out.with_suffix(".html")
        html_path.write_text(html, encoding="utf-8")
        raise RuntimeError(f"PDF generation failed. Debug HTML saved to {html_path}") from exc

    return str(out)


