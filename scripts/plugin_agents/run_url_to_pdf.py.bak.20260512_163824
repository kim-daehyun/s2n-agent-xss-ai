                }
            },
        },
        "summary": {
            "total_vulnerabilities": 1,
            "severity_counts": {"HIGH": 1},
            "plugins_run": ["xss"],
            "total_requests": 1,
        },
        "plugin_results": [
            {
                "plugin": "xss",
                "status": "SUCCESS",
                "findings": [finding],
