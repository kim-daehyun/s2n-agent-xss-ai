def _now() -> str:
    return datetime.utcnow().isoformat() + "Z"


def _safe_filename(value: str) -> str:
    cleaned = "".join(ch if ch.isalnum() else "_" for ch in value.lower())
    cleaned = "_".join(part for part in cleaned.split("_") if part)
    return cleaned[:80] or "url_xss"


def _sanitize_url(raw: str) -> str:
    text = (raw or "").strip()
    text = re.sub(r"^\s*target\s*url\s*:\s*", "", text, flags=re.I).strip()
    text = text.strip().strip('"').strip("'").strip()
    text = re.sub(r"\s+", "", text)

    if not text:
        raise ValueError("URL is empty.")

    parsed = urlparse(text)
    if parsed.scheme not in ("http", "https"):
        raise ValueError(f"Invalid URL: {text!r}. URL must start with http:// or https://")

    return text


def _sanitize_cookie(raw: str | None) -> str | None:
    if raw is None:
        return None

    text = raw.strip()
    text = re.sub(
        r"^\s*cookie\s*header\s*,?\s*optional\.?\s*press\s*enter\s*to\s*skip\s*:\s*",
        "",
        text,
        flags=re.I,
    )
    text = re.sub(r"^\s*cookie\s*header\s*:\s*", "", text, flags=re.I)
    text = text.strip().strip('"').strip("'").strip()

    if not text:
        return None

    text = re.sub(r"[\r\n\t]+", "", text)
    text = re.sub(r"\s*;\s*", "; ", text)

    return text


def _extract_cookie_value(cookie_header: str | None, name: str) -> str:
    if not cookie_header:
        return ""

    for part in cookie_header.split(";"):
        if "=" not in part:
            continue
        key, value = part.split("=", 1)
        if key.strip() == name:
            return value.strip()
    return ""


def _extract_candidate_payload(url: str) -> tuple[str, str]:
    parsed = urlparse(url)
    query = parse_qs(parsed.query, keep_blank_values=True)

    if not query:
        return "-", ""

    if "name" in query and query["name"]:
        return "name", query["name"][0]

    for key, values in query.items():
        if values:
            return key, values[0]

    return "-", ""


def _compact_url(url: str) -> str:
    parsed = urlparse(url)
    result = parsed.path or url
    if parsed.query:
        result += "?..."
    return result


def _redact_cookie(cookie_header: str | None) -> str:
    if not cookie_header:
        return "-"
    phpsessid = _extract_cookie_value(cookie_header, "PHPSESSID")
    security = _extract_cookie_value(cookie_header, "security")
    sid_hint = "-"
    if phpsessid:
        sid_hint = phpsessid[:6] + "..." + phpsessid[-4:]
    return f"PHPSESSID={sid_hint}; security={security or '-'}"


def _extract_json_object(text: str) -> Dict[str, Any] | None:
    if not text:
        return None

    # markdown code block 제거
    text = text.strip()
    text = re.sub(r"^```(?:json)?\s*", "", text, flags=re.I)
    text = re.sub(r"\s*```$", "", text)

    try:
        value = json.loads(text)
        return value if isinstance(value, dict) else None
    except Exception:
        pass

    start = text.find("{")
    end = text.rfind("}")
    if start != -1 and end != -1 and end > start:
        try:
            value = json.loads(text[start : end + 1])
            return value if isinstance(value, dict) else None
        except Exception:
            return None

    return None


def ensure_vector_index(reindex: bool = False) -> None:
    try:
        from s2n_ai.vector_rag_indexer import build_vector_index
        from s2n_ai.vector_rag_retriever import get_chroma_collection

        should_build = reindex

        if not CHROMA_DIR.exists():
            should_build = True
        else:
            try:
                collection = get_chroma_collection()
                count = collection.count()
                if count <= 0:
                    should_build = True
                else:
                    print(f"[OK] ChromaDB index ready: {count} chunks")
            except Exception as exc:
                print(f"[WARN] ChromaDB index check failed. Rebuilding index. reason={type(exc).__name__}: {exc}")
                should_build = True

        if should_build:
            print("[RAG] Building ChromaDB vector index from docs/security_guides/*.md ...")
            summary = build_vector_index(reset=True)
            print(f"[OK] ChromaDB index built: {json.dumps(summary, ensure_ascii=False)}")

    except Exception as exc:
        print(f"[WARN] ChromaDB index preparation failed. Keyword/fallback may be used. reason={type(exc).__name__}: {exc}")


def direct_xss_scan(url: str, cookie_header: str | None = None, timeout: int = 20) -> Dict[str, Any]:
    url = _sanitize_url(url)
    cookie_header = _sanitize_cookie(cookie_header)

    parameter, payload = _extract_candidate_payload(url)
    decoded_payload = unquote(payload)

    headers = {
        "User-Agent": "s2n-url-to-pdf-runner/0.5-peft",
        "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8",
    }

    if cookie_header:
        headers["Cookie"] = cookie_header

    session = requests.Session()
    response = session.get(
        url,
        timeout=timeout,
        allow_redirects=False,
        headers=headers,
    )

    body = response.text or ""

    print(f"[DEBUG] request url: {url}")
    print(f"[DEBUG] sent cookie: {_redact_cookie(cookie_header)}")
    print(f"[DEBUG] response status: {response.status_code}")
    if response.status_code in (301, 302, 303, 307, 308):
        print(f"[DEBUG] redirect location: {response.headers.get('Location', '-')}")

    if response.status_code in (301, 302, 303, 307, 308):
        location = response.headers.get("Location", "")
        raise RuntimeError(
            "Target returned redirect instead of vulnerable page. "
            f"status={response.status_code}, location={location}. "
            "This means DVWA did not accept the session cookie. "
            "Copy the CURRENT Chrome cookie values again and pass exactly: PHPSESSID=<current>; security=low"
        )

    reflected = bool(decoded_payload and decoded_payload in body)
    verification = "payload_reflected" if reflected else "not_reflected"

    if not reflected:
        snippet = body[:900].replace("\n", " ")
        raise RuntimeError(
            "Payload was not reflected in the HTTP response. "
            f"status={response.status_code}, parameter={parameter}, payload={decoded_payload!r}, "
            f"body_head={snippet[:300]!r}"
        )

    finding = {
        "id": "xss-1",
        "title": "Reflected Cross-Site Scripting Detected",
        "severity": "HIGH",
        "confidence": "FIRM",
        "url": url,
        "target_url": url,
        "method": "GET",
        "parameter": parameter,
        "payload": decoded_payload,
        "vuln_type": "XSS",
        "xss_type": "reflected",
        "cwe": "CWE-79",
        "owasp_category": "Injection / Cross-Site Scripting",
        "injection_context": "html_body",
        "parameter_location": "query",
        "sink": "http_response_html_body",
        "reflected": True,
        "reflection_detected": True,
        "reflected_value": decoded_payload,
        "verification": verification,
        "description": (
            "User-controlled input from a URL query parameter was reflected in the HTTP response "
            "without clear output encoding. The browser may interpret the reflected value as "
            "executable HTML or JavaScript."
        ),
        "evidence": (
            "Payload reflected in HTTP response without clear output encoding; "
            f"reflected_value={decoded_payload}; verification={verification}; "
            f"content_type={response.headers.get('Content-Type', '-')}; "
            f"status_code={response.status_code}; method=GET; parameter={parameter};"
        ),
        "response_snippet": body[:1800],
        "risk": {
            "risk_score": 85,
            "likelihood": "High",
            "impact": "High",
            "business_impact": (
                "An attacker may execute JavaScript in a victim browser, steal session data, "
                "perform actions as the user, or manipulate page content."
            ),
        },
        "agent_response": {
            "task": "xss_detection",
            "should_run": True,
            "context_known": True,
            "selected_plugin": "xss",
            "severity": "HIGH",
            "confidence": "FIRM",
            "fallback": True,
            "model_source": "rule_based_default_before_peft",
            "reason": "The payload was reflected in the response body without output encoding.",
        },
        "rag_hints": {
            "primary_query": (
                "reflected XSS html body output encoding missing context-aware escaping "
                f"parameter {parameter} CWE-79 remediation"
            ),
            "vuln_type": "XSS",
            "xss_type": "reflected",
            "cwe": "CWE-79",
            "owasp_category": "Injection / Cross-Site Scripting",
            "injection_context": "html_body",
            "recommended_docs": ["xss_remediation", "output_encoding", "content_security_policy"],
            "official_references": ["OWASP XSS Prevention Cheat Sheet", "CWE-79", "MDN XSS", "PortSwigger Reflected XSS"],
        },
        "report_fields": {
            "title": "Reflected Cross-Site Scripting Detected",
            "severity": "HIGH",
            "confidence": "FIRM",
            "target_url": url,
            "method": "GET",
            "parameter": parameter,
            "payload": decoded_payload,
            "reflection_detected": True,
            "reflected_value": decoded_payload,
            "verification": verification,
            "evidence": (
                "Payload reflected in HTTP response without clear output encoding; "
                f"reflected_value={decoded_payload}; verification={verification}"
            ),
            "response_snippet": body[:1800],
        },
    }

    return {
        "scan_id": "url-scan-" + datetime.utcnow().strftime("%Y%m%d%H%M%S"),
        "target_url": url,
        "scanner_version": "url-to-pdf-runner-0.5-peft",
        "start_time": _now(),
        "end_time": _now(),
        "duration_seconds": 0,
        "config": {
            "target_url": url,
            "scanner_config": {
                "crawl_depth": 0,
                "follow_redirects": False,
                "mode": "direct_url_validation",
            },
            "plugin_configs": {
                "xss": {
                    "enabled": True,
