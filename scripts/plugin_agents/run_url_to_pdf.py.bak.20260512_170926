def now_iso() -> str:
    return datetime.utcnow().isoformat() + "Z"


def safe_slug(value: str) -> str:
    text = "".join(ch if ch.isalnum() else "_" for ch in value.lower())
    text = "_".join(part for part in text.split("_") if part)
    return text[:80] or "url_xss"


def sanitize_url(raw: str) -> str:
    text = (raw or "").strip().strip('"').strip("'")
    text = re.sub(r"^\s*target\s*url\s*:\s*", "", text, flags=re.I).strip()
    text = re.sub(r"\s+", "", text)
    parsed = urlparse(text)
    if parsed.scheme not in ("http", "https") or not parsed.netloc:
        raise ValueError(f"Invalid URL: {text!r}")
    return text


def sanitize_cookie(raw: Optional[str]) -> Optional[str]:
    if raw is None:
        return None
    text = raw.strip().strip('"').strip("'")
    text = re.sub(r"^\s*cookie\s*header.*?:\s*", "", text, flags=re.I).strip()
    if not text:
        return None
    text = re.sub(r"[\r\n\t]+", "", text)
    text = re.sub(r"\s*;\s*", "; ", text)
    return text


def redact_cookie(cookie: Optional[str]) -> str:
    if not cookie:
        return "-"
    parts = []
    for item in cookie.split(";"):
        if "=" not in item:
            continue
        k, v = item.split("=", 1)
        k = k.strip()
        v = v.strip()
        if k == "PHPSESSID" and len(v) > 10:
            parts.append(f"PHPSESSID={v[:6]}...{v[-4:]}")
        else:
            parts.append(f"{k}={v}")
    return "; ".join(parts) or "-"


def make_session(cookie: Optional[str]) -> requests.Session:
    session = requests.Session()
    session.headers.update({
        "User-Agent": "s2n-url-to-pdf-browser-probe/0.8",
        "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,application/json;q=0.8,*/*;q=0.7",
    })
    if cookie:
        session.headers["Cookie"] = cookie
    return session


def first_query_param(url: str) -> Tuple[str, str]:
    parsed = urlparse(url)
    query = parse_qs(parsed.query, keep_blank_values=True)
    if not query:
        return "-", ""
    for preferred in ("name", "q", "query", "search", "keyword", "term"):
        if preferred in query and query[preferred]:
            return preferred, query[preferred][0]
    for key, values in query.items():
        return key, values[0] if values else ""
    return "-", ""


def url_contains_payload(url: str) -> bool:
    _, value = first_query_param(url)
    value = value.lower()
    return "<script" in value or "alert(" in value or "<iframe" in value


def inject_param(url: str, param: str, payload: str) -> str:
    parsed = urlparse(url)
    query = parse_qs(parsed.query, keep_blank_values=True)
    query[param] = [payload]
    return urlunparse((
        parsed.scheme,
        parsed.netloc,
        parsed.path or "/",
        parsed.params,
        urlencode(query, doseq=True),
        "",
    ))


def same_origin(a: str, b: str) -> bool:
    pa = urlparse(a)
    pb = urlparse(b)
    return pa.scheme == pb.scheme and pa.netloc == pb.netloc


def origin_of(url: str) -> str:
    p = urlparse(url)
    return f"{p.scheme}://{p.netloc}"


def compact_url(url: str) -> str:
    parsed = urlparse(url)
    out = parsed.netloc + (parsed.path or "/")
    if parsed.query:
        out += "_query"
    return out


